# SoloDeck public demo configuration
# Copy this file to .env for local Docker usage, or place these variables in ../.env.

# Optional but recommended for public demos. Visitors must enter this code before using the app.
SOLODECK_ACCESS_CODE=change-me-demo-code

# Lightweight account system.
# Keep false for low-friction demos; set true when you want every visitor to register/login.
SOLODECK_REQUIRE_LOGIN=false
SOLODECK_AUTH_DB=/app/data/solodeck_auth.db

# OpenAI-compatible endpoint.
OPENAI_BASE_URL=https://aiping.cn/api/v1
OPENAI_ENABLE_THINKING=false
OPENAI_RESPONSE_FORMAT=json_object

# Cost-aware model routing.
# BASIC: cheaper / longer context tasks.
OPENAI_API_KEY_BASIC=replace-with-basic-key
OPENAI_MODEL_BASIC=Qwen3.5-Plus

# ADVANCED: expensive / high-value review tasks.
OPENAI_API_KEY_ADVANCED=replace-with-advanced-key
OPENAI_MODEL_ADVANCED=GLM-5-Turbo

# Backward-compatible fallback.
OPENAI_API_KEY=replace-with-default-key
OPENAI_MODEL=Qwen3.5-Plus

# Optional payment display.
CREATOR_ALIPAY_ACCOUNT=your-payment-account
